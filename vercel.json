{
  "version": 2,
  "cleanUrls": true,
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://qma-api.onrender.com/api/:path*"
    },
    {
      "source": "/profile",
      "destination": "/user.html"
    },
    {
      "source": "/user",
      "destination": "/user.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/marketplace",
      "destination": "/marketplace.html"
    },
    {
      "source": "/docs",
      "destination": "/docs.html"
    }
  ]
}