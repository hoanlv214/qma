{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://qma-api.onrender.com/api/:path*"
    },
    {
      "source": "/docs",
      "destination": "https://qma-api.onrender.com/docs"
    },
    {
      "source": "/openapi.json",
      "destination": "https://qma-api.onrender.com/openapi.json"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
