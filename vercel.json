{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "pages/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "pages/app.html",
      "use": "@vercel/static"
    },
    {
      "src": "pages/user.html",
      "use": "@vercel/static"
    },
    {
      "src": "pages/marketplace.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/app",
      "destination": "/pages/app.html"
    },
    {
      "source": "/user",
      "destination": "/pages/user.html"
    },
    {
      "source": "/marketplace",
      "destination": "/pages/marketplace.html"
    }
  ]
}
