{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "pages/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "pages/app.html",
      "use": "@vercel/static"
    },
    {
      "src": "pages/user.html",
      "use": "@vercel/static"
    },
    {
      "src": "pages/marketplace.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/pages/index.html"
    },
    {
      "src": "/app",
      "dest": "/pages/app.html"
    },
    {
      "src": "/user",
      "dest": "/pages/user.html"
    },
    {
      "src": "/marketplace",
      "dest": "/pages/marketplace.html"
    },
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    }
  ]
}
