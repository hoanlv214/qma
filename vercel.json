{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "frontend/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/app/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/landing",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/lading",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/app",
      "dest": "/frontend/app/index.html"
    },
    {
      "src": "/public/(.*)",
      "dest": "/frontend/public/$1"
    },
    {
      "handle": "filesystem"
    }
  ]
}
