{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/landing",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/lading",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/app",
      "destination": "/frontend/app/index.html"
    },
    {
      "source": "/public/:path*",
      "destination": "/frontend/public/:path*"
    }
  ]
}
