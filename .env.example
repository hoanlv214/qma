# QMA minimal environment
# Copy to .env, then fill only the values that are specific to your deployment.

# Wallet roles
# Platform treasury: receives the platform leg of direct x402 split revenue.
QMA_PLATFORM_TREASURY_ADDRESS=0xplatform_treasury_wallet
# Backward-compatible alias used by older docs/deploys.
QMA_ARC_SELLER_ADDRESS=0xplatform_treasury_wallet

# Provider owner wallets: used for creator/provider accounting and claimable revenue.
QMA_FUNDING_MEMORY_OWNER_WALLET=0xfunding_provider_owner_wallet
QMA_OI_MEMORY_OWNER_WALLET=0xoi_provider_owner_wallet

# Admin wallet/token: approves providers and writes admin-only marketplace actions.
QMA_ADMIN_WALLET=0xadmin_wallet
QMA_ADMIN_TOKEN=replace-with-admin-review-token

# Future gasless withdraw relayer. Address is public; private key must stay server-only.
QMA_WITHDRAW_RELAYER_ADDRESS=0xhot_relayer_wallet
# QMA_WITHDRAW_RELAYER_PRIVATE_KEY=0xnever_commit_real_or_funded_private_keys

# Creator claim payout executor. This hot wallet must hold Arc USDC for creator payouts.
# If omitted, arc_gateway falls back to QMA_WITHDRAW_RELAYER_PRIVATE_KEY for local testing.
# QMA_CREATOR_CLAIM_PAYOUT_PRIVATE_KEY=0xnever_commit_real_or_funded_private_keys
# Internal secret used only for qma-api <-> arc_gateway server calls.
QMA_ARC_GATEWAY_INTERNAL_SECRET=replace-with-sidecar-internal-secret

# Server secrets
QMA_ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
# Buyer-visible split-leg URL signing secret. Keep separate from QMA_ARC_GATEWAY_INTERNAL_SECRET.
QMA_SPLIT_LEG_URL_SECRET=replace-with-different-split-url-secret

# Persistent storage. Leave service role blank for local JSON fallback.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-server-only
SUPABASE_SCHEMA=public

# Data paths. Keep sample paths for local demo; override for private/full datasets.
QMA_HISTORICAL_DB_PATH=qma/data/sample_funding_historical_analysis.csv
QMA_BACKTEST_OUTCOME_PATH=qma/data/sample_trading_analysis.csv

# Local sidecar URL. For production, set this to the deployed arc_gateway service URL.
QMA_ARC_GATEWAY_URL=http://127.0.0.1:3000
