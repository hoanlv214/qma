# QMA local development overrides
# Use together with .env.example when running both services on your machine.

QMA_ARC_GATEWAY_URL=http://127.0.0.1:3000
QMA_API_URL=http://127.0.0.1:8000

# Demo pricing
QMA_PRICE_PREVIEW_USDC=0.001
QMA_PRICE_FULL_USDC=0.005
QMA_PAYMENT_AMOUNT_USDC=0.005
QMA_PRICE_COMPLEXITY_UPLIFT_MAX=0

# Buyer Gateway preload UX
QMA_ARC_DEFAULT_DEPOSIT_USDC=1.00
QMA_ARC_DEFAULT_APPROVE_USDC=10.00

# CLI agent buyer demo only
AGENT_PRIVATE_KEY=0xnever_commit_real_or_funded_private_keys
AGENT_BUDGET_USDC=0.01
AGENT_MAX_PRICE_USDC=0.005
AGENT_GATEWAY_DEPOSIT_USDC=1
AGENT_GATEWAY_APPROVE_USDC=10
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
