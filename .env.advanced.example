# QMA advanced/optional environment
# Most of these have safe defaults in source code. Add only when you need to override behavior.

# Public Arc/Circle constants. Usually do not override on Arc Testnet.
QMA_SETTLEMENT_RAIL=circle_gateway_x402
QMA_PAYMENT_RESOURCE_TYPE=qma_signal_report
QMA_PAYMENT_NETWORK=eip155:5042002
QMA_PAYMENT_NETWORK_NAME=Arc Testnet
QMA_CIRCLE_GATEWAY_API=https://gateway-api-testnet.circle.com
QMA_ARC_EXPLORER=https://testnet.arcscan.app
QMA_ARC_GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
QMA_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Provider pricing overrides. If omitted, providers inherit QMA_PRICE_PREVIEW_USDC/QMA_PRICE_FULL_USDC.
QMA_PROVIDER_FUNDING_MEMORY_PRICE_PREVIEW_USDC=0.001
QMA_PROVIDER_FUNDING_MEMORY_PRICE_FULL_USDC=0.005
QMA_PROVIDER_OI_MEMORY_PRICE_PREVIEW_USDC=0.001
QMA_PROVIDER_OI_MEMORY_PRICE_FULL_USDC=0.005
QMA_DEMO_CREATOR_WALLET=0x2222222222222222222222222222222222222222
QMA_DISABLED_PROVIDERS=

# Invoice/access behavior
QMA_INVOICE_TTL_SECONDS=900
QMA_SPLIT_INVOICE_TTL_SECONDS=1800
QMA_DEFAULT_SETTLEMENT_MODE=x402_direct_split
QMA_ACCESS_TOKEN_TTL_SECONDS=300
QMA_REQUIRE_COMPLETED_SETTLEMENT=false

# Withdraw relay
# seller_wallet: browser/seller pays gas for gatewayMint.
# platform_relayed: arc_gateway hot wallet submits gatewayMint and pays gas.
QMA_WITHDRAW_MODE=seller_wallet
# Set this only on the arc_gateway server when QMA_WITHDRAW_MODE=platform_relayed.
# QMA_WITHDRAW_RELAYER_PRIVATE_KEY=0xnever_commit_real_or_funded_private_keys
QMA_MIN_PROVIDER_WITHDRAW_USDC=0
QMA_PROVIDER_WITHDRAW_DAILY_LIMIT=1

# Creator claim payout
# MVP mode uses a server-side payout executor wallet that transfers Arc USDC to creators after ledger verification.
# For local testing this can be the same hot wallet as QMA_WITHDRAW_RELAYER_PRIVATE_KEY.
# In production, keep only a small operating balance here and protect the sidecar with QMA_ARC_GATEWAY_INTERNAL_SECRET.
QMA_CREATOR_CLAIM_MIN_USDC=0
QMA_CREATOR_CLAIM_INTENT_TTL_SECONDS=600
# QMA_CREATOR_CLAIM_PAYOUT_PRIVATE_KEY=0xnever_commit_real_or_funded_private_keys
# QMA_ARC_GATEWAY_INTERNAL_SECRET=replace-with-sidecar-internal-secret
# QMA_SPLIT_LEG_URL_SECRET=replace-with-different-buyer-visible-url-secret
# QMA_SPLIT_RECEIPT_SECRET=replace-with-sidecar-receipt-secret
# QMA_BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Rate limiting
QMA_RATE_LIMIT_ENABLED=true
QMA_RATE_LIMIT_WINDOW_SECONDS=60
QMA_RATE_LIMIT_PAYMENT_VERIFY_PER_MIN=8
QMA_RATE_LIMIT_INVOICE_PER_MIN=20
QMA_RATE_LIMIT_REPORT_PER_MIN=30
QMA_RATE_LIMIT_PUBLIC_MARKET_PER_MIN=120
QMA_RATE_LIMIT_CREATOR_APPLY_PER_MIN=6
QMA_RATE_LIMIT_API_DEFAULT_PER_MIN=240

# Market data adapter
QMA_MARKET_DATA_SOURCE=mexc_futures
QMA_MARKET_DATA_CACHE_DIR=
QMA_MEXC_FETCH_CONTRACT_DETAILS=false
QMA_MEXC_DETAIL_CACHE_TTL_SECONDS=21600
QMA_MEXC_FUNDING_THRESHOLD=-0.0025
QMA_LIVE_ANOMALY_LIMIT=12

# Payment event/index refresh tuning
QMA_ARC_BATCH_TX_CACHE_TTL_SECONDS=60
QMA_PAYMENT_EVENT_REFRESH_TTL_SECONDS=90
